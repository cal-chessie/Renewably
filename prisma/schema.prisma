generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== CRM USER =====
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String
  role          String   @default("agent") // admin, agent, viewer
  avatar        String?
  phone         String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  activities    Activity[]
  tasks         Task[]
  assignedDeals Deal[]    @relation("DealAssignee")
  createdDeals  Deal[]    @relation("DealCreator")
  notes         Note[]
  meetings      Meeting[]
}

// ===== COMPANY =====
model Company {
  id           String    @id @default(cuid())
  name         String
  website      String?
  industry     String?
  employees    Int?
  annualRevenue String?
  address      String?
  city         String?
  country      String?
  phone        String?
  description  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  contacts     Contact[]
  deals        Deal[]
  notes        Note[]
  activities   Activity[]
  proposals    Proposal[]
  meetings     Meeting[]
}

// ===== CONTACT =====
model Contact {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  email        String?
  phone        String?
  jobTitle     String?
  linkedin     String?
  source       String    @default("website") // website, referral, linkedin, cold, event, other
  status       String    @default("lead") // lead, prospect, customer, churned, inactive
  address      String?
  city         String?
  country      String?
  avatar       String?
  description  String?
  lastContactAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  companyId    String?
  company      Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  deals        Deal[]
  activities   Activity[]
  tasks        Task[]
  notes        Note[]
  tags         ContactTag[]
  proposals    Proposal[]
  meetings     Meeting[]
}

// ===== PIPELINE STAGE =====
model PipelineStage {
  id          String @id @default(cuid())
  name        String
  order       Int
  color       String @default("#F3D840")
  isDefault   Boolean @default(false)

  deals       Deal[]

  @@unique([name])
}

// ===== DEAL =====
model Deal {
  id              String         @id @default(cuid())
  title           String
  value           Float          @default(0)
  currency        String         @default("EUR")
  probability     Int            @default(50)
  closeDate       DateTime?
  lostReason      String?
  description     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  stageId         String
  stage           PipelineStage  @relation(fields: [stageId], references: [id])

  contactId       String?
  contact         Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)

  companyId       String?
  company         Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)

  assigneeId      String?
  assignee        User?          @relation("DealAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  creatorId       String?
  creator         User?          @relation("DealCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  activities      Activity[]
  tasks           Task[]
  notes           Note[]
  tags            DealTag[]
  proposals       Proposal[]
  meetings        Meeting[]
}

// ===== ACTIVITY =====
model Activity {
  id          String   @id @default(cuid())
  type        String   // call, email, meeting, note, task, deal_update, system
  subject     String
  description String?
  duration    Int?     // minutes
  status      String?  // completed, scheduled, cancelled, in_progress
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  proposalId  String?
  proposal    Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)

  meetingId   String?
  meeting     Meeting?  @relation(fields: [meetingId], references: [id], onDelete: SetNull)
}

// ===== TASK =====
model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  priority    String   @default("medium") // low, medium, high, urgent
  status      String   @default("todo") // todo, in_progress, completed, cancelled
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  assigneeId  String?
  assignee    User?    @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  notes           Note[]
  meetingFollowUps Meeting[] @relation("MeetingFollowUp")
}

// ===== NOTE =====
model Note {
  id          String   @id @default(cuid())
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

// ===== TAG =====
model Tag {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String   @default("#F3D840")
  createdAt   DateTime @default(now())

  contacts    ContactTag[]
  deals       DealTag[]
}

// ===== PROPOSAL =====
model Proposal {
  id          String   @id @default(cuid())
  title       String
  dealId      String?
  contactId   String?
  companyId   String?
  status      String   @default("draft")  // draft, sent, viewed, accepted, rejected, expired
  totalAmount Float
  validUntil  DateTime?
  sentAt      DateTime?
  viewedAt    DateTime?
  acceptedAt  DateTime?
  rejectedAt  DateTime?
  notes       String?
  templateId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deal      Deal?            @relation(fields: [dealId], references: [id])
  contact   Contact?         @relation(fields: [contactId], references: [id])
  company   Company?         @relation(fields: [companyId], references: [id])
  template  ProposalTemplate? @relation(fields: [templateId], references: [id])
  lineItems ProposalLineItem[]
  activities Activity[]
}

// ===== PROPOSAL LINE ITEM =====
model ProposalLineItem {
  id          String   @id @default(cuid())
  proposalId  String
  name        String
  description String?
  quantity    Int
  unitPrice   Float
  total       Float
  sortOrder   Int      @default(0)

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

// ===== PROPOSAL TEMPLATE =====
model ProposalTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  lineItems   String   @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  proposals Proposal[]
}

// ===== CONTACT TAG (Junction) =====
model ContactTag {
  contactId   String
  contact     Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tagId       String
  tag         Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

// ===== DEAL TAG (Junction) =====
model DealTag {
  dealId      String
  deal        Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tagId       String
  tag         Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([dealId, tagId])
}

// ===== MEETING =====
model Meeting {
  id              String    @id @default(cuid())
  title           String
  description     String?
  date            DateTime
  endDate         DateTime
  location        String?
  meetingType     String    @default("call")  // call, video, in_person
  status          String    @default("scheduled")  // scheduled, completed, cancelled, no_show
  contactId       String?
  dealId          String?
  companyId       String?
  assignedTo      String?
  notes           String?
  followUpTaskId  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contact         Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal            Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  company         Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignee        User?     @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  followUpTask    Task?     @relation("MeetingFollowUp", fields: [followUpTaskId], references: [id], onDelete: SetNull)
  activities      Activity[]
}

// ===== WORKFLOW RULE =====
model WorkflowRule {
  id              String              @id @default(cuid())
  name            String
  description     String?
  isActive        Boolean             @default(true)
  triggerType     String              // deal_stage_change, new_contact, task_overdue, proposal_status_change, contact_inactive
  triggerConfig   String              // JSON string: { "stage": "qualified", "days": 7 } etc
  actions         String              // JSON string: [{ "type": "assign_task", "config": {...} }, ...]
  executionCount  Int                 @default(0)
  lastExecutedAt  DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  executions      WorkflowExecution[]
}

// ===== WORKFLOW EXECUTION =====
model WorkflowExecution {
  id            String       @id @default(cuid())
  ruleId        String
  rule          WorkflowRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  triggerType   String
  entityType    String       // deal, contact, task, proposal
  entityId      String
  actionType    String       // assign_task, send_email, update_field, notify, move_stage
  actionConfig  String       // JSON string
  status        String       @default("success")  // success, failed, skipped
  result        String?
  executedAt    DateTime     @default(now())

  @@index([ruleId])
  @@index([entityType, entityId])
}

// ===== REPORT =====
model Report {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // pipeline, revenue, activity, forecast, custom
  config      String   @default("{}") // JSON string: report configuration (filters, metrics, date range)
  isScheduled Boolean  @default(false)
  schedule    String?  // daily, weekly, monthly
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  snapshots ReportSnapshot[]
}

// ===== REPORT SNAPSHOT =====
model ReportSnapshot {
  id          String   @id @default(cuid())
  reportId    String
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  data        String   @default("{}") // JSON string: snapshot of report data
  generatedAt DateTime @default(now())
}
