generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== CRM USER =====
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  password      String
  role          String   @default("agent") // admin, agent, viewer
  avatar        String?
  phone         String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  activities    Activity[]
  tasks         Task[]
  assignedDeals Deal[]    @relation("DealAssignee")
  createdDeals  Deal[]    @relation("DealCreator")
  notes         Note[]
  meetings      Meeting[]
  googleCalendar GoogleCalendarConnection?
  installerProfile   InstallerProfile?
}

// ===== COMPANY =====
model Company {
  id           String    @id @default(uuid())
  name         String
  website      String?
  industry     String?
  employees    Int?
  annualRevenue String?
  address      String?
  city         String?
  country      String?
  phone        String?
  description  String?  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  contacts     Contact[]
  deals        Deal[]
  notes        Note[]
  activities   Activity[]
  proposals    Proposal[]
  meetings     Meeting[]
  invoices     Invoice[]
  installerProfile InstallerProfile?
}

// ===== CONTACT =====
model Contact {
  id           String    @id @default(uuid())
  firstName    String
  lastName     String
  email        String?
  phone        String?
  jobTitle     String?
  linkedin     String?
  source       String    @default("website") // website, referral, linkedin, cold, event, other
  status       String    @default("lead") // lead, prospect, customer, churned, inactive
  address      String?
  city         String?
  country      String?
  avatar       String?
  description  String?  
  lastContactAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  companyId    String?  
  company      Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  deals        Deal[]
  activities   Activity[]
  tasks        Task[]
  notes        Note[]
  tags         ContactTag[]
  proposals    Proposal[]
  meetings     Meeting[]
  invoices     Invoice[]
  installerProfile InstallerProfile?
}

// ===== PIPELINE STAGE =====
model PipelineStage {
  id          String @id @default(uuid())
  name        String
  order       Int
  color       String @default("#F3D840")
  isDefault   Boolean @default(false)

  deals       Deal[]

  @@unique([name])
}

// ===== DEAL =====
model Deal {
  id              String         @id @default(uuid())
  title           String
  value           Float          @default(0)
  currency        String         @default("EUR")
  probability     Int            @default(50)
  closeDate       DateTime?
  lostReason      String?       
  description     String?       
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  stageId         String        
  stage           PipelineStage  @relation(fields: [stageId], references: [id])

  contactId       String?       
  contact         Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)

  companyId       String?       
  company         Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)

  assigneeId      String?       
  assignee        User?          @relation("DealAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  creatorId       String?       
  creator         User?          @relation("DealCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  activities      Activity[]
  tasks           Task[]
  notes           Note[]
  tags            DealTag[]
  proposals       Proposal[]
  meetings        Meeting[]
  invoices        Invoice[]
}

// ===== ACTIVITY =====
model Activity {
  id          String   @id @default(uuid())
  type        String   // call, email, meeting, note, task, deal_update, system
  subject     String
  description String? 
  duration    Int?     // minutes
  status      String?  // completed, scheduled, cancelled, in_progress
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  contactId   String? 
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  dealId      String? 
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  companyId   String? 
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  userId      String? 
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  proposalId  String? 
  proposal    Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)

  meetingId   String? 
  meeting     Meeting?  @relation(fields: [meetingId], references: [id], onDelete: SetNull)

  invoiceId   String? 
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
}

// ===== TASK =====
model Task {
  id          String   @id @default(uuid())
  title       String
  description String? 
  priority    String   @default("medium") // low, medium, high, urgent
  status      String   @default("todo") // todo, in_progress, completed, cancelled
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contactId   String? 
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  dealId      String? 
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  assigneeId  String? 
  assignee    User?    @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  notes           Note[]
  meetingFollowUps Meeting[] @relation("MeetingFollowUp")
}

// ===== NOTE =====
model Note {
  id          String   @id @default(uuid())
  content     String  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contactId   String? 
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  dealId      String? 
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  companyId   String? 
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  userId      String? 
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  taskId      String? 
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

// ===== TAG =====
model Tag {
  id          String   @id @default(uuid())
  name        String   @unique
  color       String   @default("#F3D840")
  createdAt   DateTime @default(now())

  contacts    ContactTag[]
  deals       DealTag[]
}

// ===== PROPOSAL =====
model Proposal {
  id          String   @id @default(uuid())
  title       String
  dealId      String? 
  contactId   String? 
  companyId   String? 
  status      String   @default("draft")  // draft, sent, viewed, accepted, rejected, expired
  totalAmount Float
  validUntil  DateTime?
  sentAt      DateTime?
  viewedAt    DateTime?
  acceptedAt  DateTime?
  rejectedAt  DateTime?
  notes       String? 
  templateId  String? 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deal      Deal?            @relation(fields: [dealId], references: [id])
  contact   Contact?         @relation(fields: [contactId], references: [id])
  company   Company?         @relation(fields: [companyId], references: [id])
  template  ProposalTemplate? @relation(fields: [templateId], references: [id])
  lineItems ProposalLineItem[]
  activities Activity[]
  invoices   Invoice[]
}

// ===== INVOICE =====
model Invoice {
  id            String    @id @default(uuid())
  invoiceNumber String    @unique
  proposalId    String?  
  contactId     String?  
  companyId     String?  
  dealId        String?  
  status        String    @default("draft")
  subtotal      Float
  taxRate       Float     @default(0)
  taxAmount     Float     @default(0)
  totalAmount   Float
  dueDate       DateTime?
  sentAt        DateTime?
  paidAt        DateTime?
  notes         String?  
  branding      String    @default("renewably")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  proposal      Proposal?        @relation(fields: [proposalId], references: [id])
  contact       Contact?         @relation(fields: [contactId], references: [id])
  company       Company?         @relation(fields: [companyId], references: [id])
  deal          Deal?            @relation(fields: [dealId], references: [id])
  lineItems     InvoiceLineItem[]
  payments      Payment[]
  activities    Activity[]
}

// ===== INVOICE LINE ITEM =====
model InvoiceLineItem {
  id          String   @id @default(uuid())
  invoiceId   String  
  name        String
  description String? 
  quantity    Int
  unitPrice   Float
  total       Float
  sortOrder   Int      @default(0)

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ===== PAYMENT =====
model Payment {
  id            String   @id @default(uuid())
  invoiceId     String  
  amount        Float
  method        String
  status        String   @default("completed")
  reference     String?
  notes         String? 
  paidAt        DateTime @default(now())
  createdAt     DateTime @default(now())

  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ===== PROPOSAL LINE ITEM =====
model ProposalLineItem {
  id          String   @id @default(uuid())
  proposalId  String  
  name        String
  description String? 
  quantity    Int
  unitPrice   Float
  total       Float
  sortOrder   Int      @default(0)

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

// ===== PROPOSAL TEMPLATE =====
model ProposalTemplate {
  id          String   @id @default(uuid())
  name        String
  description String? 
  lineItems   String   @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  proposals Proposal[]
}

// ===== CONTACT TAG (Junction) =====
model ContactTag {
  contactId   String  
  contact     Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tagId       String  
  tag         Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

// ===== DEAL TAG (Junction) =====
model DealTag {
  dealId      String  
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tagId       String  
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([dealId, tagId])
}

// ===== MEETING =====
model Meeting {
  id              String    @id @default(uuid())
  title           String
  description     String?  
  date            DateTime
  endDate         DateTime
  location        String?
  meetingType     String    @default("call")  // call, video, in_person
  status          String    @default("scheduled")  // scheduled, completed, cancelled, no_show
  contactId       String?  
  dealId          String?  
  companyId       String?  
  assignedTo      String?  
  notes           String?  
  followUpTaskId  String?  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contact         Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal            Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  company         Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignee        User?     @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  followUpTask    Task?     @relation("MeetingFollowUp", fields: [followUpTaskId], references: [id], onDelete: SetNull)
  activities      Activity[]
}

// ===== WORKFLOW RULE =====
model WorkflowRule {
  id              String              @id @default(uuid())
  name            String
  description     String?            
  isActive        Boolean             @default(true)
  triggerType     String              // deal_stage_change, new_contact, task_overdue, proposal_status_change, contact_inactive
  triggerConfig   String              // JSON string: { "stage": "qualified", "days": 7 } etc
  actions         String              // JSON string: [{ "type": "assign_task", "config": {...} }, ...]
  executionCount  Int                 @default(0)
  lastExecutedAt  DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  executions      WorkflowExecution[]
}

// ===== WORKFLOW EXECUTION =====
model WorkflowExecution {
  id            String       @id @default(uuid())
  ruleId        String      
  rule          WorkflowRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  triggerType   String
  entityType    String       // deal, contact, task, proposal
  entityId      String      
  actionType    String       // assign_task, send_email, update_field, notify, move_stage
  actionConfig  String       // JSON string
  status        String       @default("success")  // success, failed, skipped
  result        String?     
  executedAt    DateTime     @default(now())

  @@index([ruleId])
  @@index([entityType, entityId])
}

// ===== GOOGLE CALENDAR CONNECTION =====
model GoogleCalendarConnection {
  id            String   @id @default(uuid())
  userId        String   @unique
  accessToken   String  
  refreshToken  String  
  expiresAt     DateTime
  calendarId    String?
  email         String?
  isActive      Boolean  @default(true)
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
}

// ===== REPORT =====
model Report {
  id          String   @id @default(uuid())
  name        String
  description String? 
  type        String   // pipeline, revenue, activity, forecast, custom
  config      String   @default("{}") // JSON string: report configuration (filters, metrics, date range)
  isScheduled Boolean  @default(false)
  schedule    String?  // daily, weekly, monthly
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  snapshots ReportSnapshot[]
}

// ===== REPORT SNAPSHOT =====
model ReportSnapshot {
  id          String   @id @default(uuid())
  reportId    String  
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  data        String   @default("{}") // JSON string: snapshot of report data
  generatedAt DateTime @default(now())
}

// ===== Installer Profile (onboarding data) =====
model InstallerProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId             String   @unique
  contact               Contact  @relation(fields: [contactId], references: [id])
  companyId             String   @unique
  company               Company  @relation(fields: [companyId], references: [id])

  companyName           String
  contactName           String
  phone                 String?
  vatNumber             String?
  businessAddress       String? 

  serviceCounties       String   @default("[]")

  planId                String   @default("pro")
  billingCycle          String   @default("monthly")
  billingEmail          String?
  billingAddress        String? 
  billingCity           String?
  billingCounty         String?
  billingEircode        String?
  stripeCustomerId      String?

  integrations          String   @default("[]")
  securityFeatures      String   @default("[]")

  yearsInBusiness       Int?
  publicLiability       Float?
  seaiRegistered        Boolean  @default(false)
  seaiNumber            String?
  reciRegistered        Boolean  @default(false)
  reciNumber            String?
  maxProjectsMonth      Int?
  avgProjectValue       Float?
  avgInstallDays        Int?
  teamSize              Int?
  qualifiedElectricians Int?
  vanFleetSize          Int?
  hasDrone              Boolean  @default(false)
  hasScaffolding        Boolean  @default(false)
  maxLeadsMonth         Int?
  minLeadValue          Float?
  responseTimeHours     Int?
  quotationTurnaround   Int?
  maxTravelKm           Int?
  ruralSpecialist       Boolean  @default(false)
  commercialSpecialist  Boolean  @default(false)
  heritageExperience    Boolean  @default(false)
  offersEvCharger       Boolean  @default(false)
  offersHeatPump        Boolean  @default(false)
  acceptsFinancing      Boolean  @default(true)

  leadTargetMonth       Int?
  installsMonth         Int?
  revenueTarget         Float?

  onboardingComplete    Boolean  @default(false)
  onboardingStep        Int      @default(0)
  trialStartAt          DateTime?
  trialEndsAt           DateTime?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  equipment             InstallerEquipment[]
  signedDocuments       InstallerDocument[]
  subscription          Subscription?
}

// ===== INSTALLER EQUIPMENT =====
model InstallerEquipment {
  id          String   @id @default(uuid())
  installerId String  
  installer   InstallerProfile @relation(fields: [installerId], references: [id], onDelete: Cascade)
  category    String
  brandId     String  
  brandName   String
  meta        String   @default("{}")
  isPreferred Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([installerId, category])
}

// ===== INSTALLER DOCUMENT =====
model InstallerDocument {
  id          String   @id @default(uuid())
  installerId String  
  installer   InstallerProfile @relation(fields: [installerId], references: [id], onDelete: Cascade)
  docType     String
  docName     String
  fileName    String?
  signedAt    DateTime?
  createdAt   DateTime @default(now())

  @@unique([installerId, docType])
}

// ===== SUBSCRIPTION =====
model Subscription {
  id                  String   @id @default(uuid())
  installerId         String   @unique
  installer           InstallerProfile @relation(fields: [installerId], references: [id], onDelete: Cascade)
  planId              String   @default("pro")
  status              String   @default("trialing")
  billingCycle        String   @default("monthly")
  currentPeriodStart  DateTime @default(now())
  currentPeriodEnd    DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
