# ============================================================================
# RENEWABLY CRM — Environment Variables Template
# ============================================================================
# Copy this file to .env.local for development or .env.production for prod.
# NEVER commit secrets to version control.
# ============================================================================

# ── Supabase (PostgreSQL) ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Public URL (for password reset redirects, OAuth, etc.) ──────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Postmark (Transactional Email) ─────────────────────────────────────────
POSTMARK_SERVER_TOKEN=your-postmark-token
POSTMARK_FROM_EMAIL=hello@renewably.ie
POSTMARK_WEBHOOK_SIGNATURE=
FROM_EMAIL=hello@renewably.ie

# ── Stripe (Payments) ──────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_STARTER=price_placeholder_starter
STRIPE_PRICE_PRO=price_placeholder_pro
STRIPE_PRICE_ENTERPRISE=price_placeholder_enterprise

# ── Redis (Rate Limiting & Caching) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Anthropic (AI Assistant) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key
AGENT_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# ── Google (Calendar Sync) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Analytics (optional — tracking pixels) ─────────────────────────────────
GA_MEASUREMENT_ID=
GTM_CONTAINER_ID=
FB_PIXEL_ID=
IG_BUSINESS_ACCOUNT_ID=

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
